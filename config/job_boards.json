  "ats_platforms": {
    "lever": {
      "description": "Lever ATS - public postings API returns JSON, no auth required",
      "api_base": "https://api.lever.co/v0/postings/{company}",
      "web_base": "https://jobs.lever.co/{company}",
      "access_method": "api",
      "api_details": {
        "method": "GET",
        "format": "JSON (use ?mode=json)",
        "pagination": "?skip=0&limit=100",
        "response_fields": ["id", "text", "categories", "description", "hostedUrl", "applyUrl", "createdAt"]
      },
      "example_companies": {
        "spotify": {
          "api": "https://api.lever.co/v0/postings/spotify?mode=json",
          "web": "https://jobs.lever.co/spotify"
